{
  "default_branch": "main",
  "allow_auto_merge": true,
  "delete_branch_on_merge": true,
  "required_status_checks": {
    "strict": true,
    "contexts": [
      "rustfmt",
      "nextest (ubuntu-latest)",
      "nextest (macos-latest)",
      "coverage",
      "docs-site"
    ]
  },
  "pages": {
    "enabled": true,
    "build_type": "workflow"
  }
}
